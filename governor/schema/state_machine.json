{
  "_meta": {
    "schema_version": "1.1",
    "version": "2.0.0",
    "previous_version": "1.0.0",
    "description": "Task State Machine definition. Single source of truth for all legal state transitions, role authorization, and guards.",
    "created": "2026-02-20",
    "updated": "2026-03-03",
    "owner": "governor",
    "migration_notes": "v2.0.0 adds BLOCKED and FAILED terminal states. Existing tasks in ACTIVE/READY_FOR_REVIEW/REWORK are unaffected. See docs/MIGRATION.md for details."
  },
  "states": {
    "ACTIVE": {
      "description": "Executor is working on the task",
      "terminal": false
    },
    "READY_FOR_REVIEW": {
      "description": "Executor submitted work for review",
      "terminal": false
    },
    "COMPLETED": {
      "description": "Reviewer approved; task finished successfully",
      "terminal": true
    },
    "REWORK": {
      "description": "Reviewer returned task for revision",
      "terminal": false
    },
    "BLOCKED": {
      "description": "Task is waiting on an external dependency or condition",
      "terminal": false
    },
    "FAILED": {
      "description": "Task exhausted rework attempts or was abandoned",
      "terminal": true
    }
  },
  "transitions": [
    {
      "id": "T01",
      "from_state": "ACTIVE",
      "to_state": "READY_FOR_REVIEW",
      "description": "Executor submission gate",
      "allowed_roles": [
        "EXECUTOR"
      ],
      "guards": [
        "EG-01",
        "EG-02",
        "EG-03",
        "EG-04",
        "EG-05",
        "EG-06",
        "EG-07",
        "EG-08"
      ],
      "events": [],
      "temporal_fields": {
        "set": [
          "submitted_date"
        ]
      },
      "notes": "EG guards validate evidence and deliverables before submission."
    },
    {
      "id": "T02",
      "from_state": "READY_FOR_REVIEW",
      "to_state": "COMPLETED",
      "description": "Reviewer approves - task finished",
      "allowed_roles": [
        "REVIEWER"
      ],
      "guards": [
        "EG-01",
        "EG-02",
        "EG-03",
        "EG-04",
        "EG-05",
        "EG-06",
        "EG-07",
        "EG-08"
      ],
      "events": [],
      "temporal_fields": {
        "set": [
          "completed_date"
        ]
      },
      "notes": "Terminal transition. COMPLETED has no outbound transitions."
    },
    {
      "id": "T03",
      "from_state": "READY_FOR_REVIEW",
      "to_state": "REWORK",
      "description": "Reviewer returns task for revision",
      "allowed_roles": [
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "clear": [
          "submitted_date"
        ],
        "increment": [
          "revision_count"
        ]
      },
      "notes": "Unconditional - the reviewer's decision to request rework needs no guard. Increments revision_count for tracking."
    },
    {
      "id": "T04",
      "from_state": "REWORK",
      "to_state": "READY_FOR_REVIEW",
      "description": "Executor resubmits after revision",
      "allowed_roles": [
        "EXECUTOR"
      ],
      "guards": [
        "EG-01",
        "EG-02",
        "EG-03",
        "EG-04",
        "EG-05",
        "EG-06",
        "EG-07",
        "EG-08"
      ],
      "events": [],
      "temporal_fields": {
        "set": [
          "submitted_date"
        ]
      },
      "notes": "Same guards as T01 - executor must re-satisfy all evidence contracts."
    },
    {
      "id": "T05",
      "from_state": "ACTIVE",
      "to_state": "BLOCKED",
      "description": "Task blocked on external dependency",
      "allowed_roles": [
        "EXECUTOR",
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "set": [
          "blocked_date"
        ]
      },
      "notes": "Either role can block a task. Requires blocking_reason in transition_params."
    },
    {
      "id": "T06",
      "from_state": "BLOCKED",
      "to_state": "ACTIVE",
      "description": "Blocked task resumed after dependency resolved",
      "allowed_roles": [
        "EXECUTOR",
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "clear": [
          "blocked_date"
        ]
      },
      "notes": "Either role can unblock. Requires unblock_reason in transition_params."
    },
    {
      "id": "T07",
      "from_state": "REWORK",
      "to_state": "FAILED",
      "description": "Task failed after exhausting rework attempts",
      "allowed_roles": [
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "set": [
          "failed_date"
        ]
      },
      "notes": "Terminal transition. Used when a task cannot be satisfactorily completed. Requires failure_reason in transition_params."
    },
    {
      "id": "T08",
      "from_state": "ACTIVE",
      "to_state": "FAILED",
      "description": "Task abandoned or cancelled",
      "allowed_roles": [
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "set": [
          "failed_date"
        ]
      },
      "notes": "Terminal transition. Used to abandon a task that should not continue. Requires failure_reason in transition_params."
    },
    {
      "id": "T09",
      "from_state": "BLOCKED",
      "to_state": "FAILED",
      "description": "Blocked task abandoned due to unresolvable dependency",
      "allowed_roles": [
        "REVIEWER"
      ],
      "guards": [],
      "events": [],
      "temporal_fields": {
        "set": [
          "failed_date"
        ]
      },
      "notes": "Terminal transition. Used when a blocked task's dependency cannot be resolved."
    }
  ],
  "template_variables": {
    "$task_id": "Task ID",
    "$task_name": "Human-readable task name",
    "$task_role": "Role assigned to the task",
    "$task_priority": "Task priority (CRITICAL, HIGH, MEDIUM, LOW)"
  },
  "illegal_transitions_note": "Any transition not listed above is ILLEGAL and will be rejected with error ILLEGAL_TRANSITION. COMPLETED and FAILED are terminal - no outbound transitions. 9 transitions total (T01-T09)."
}
